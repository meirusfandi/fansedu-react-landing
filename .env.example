# Base URL API (LMS + landing packages). Sama dengan BASE di docs/API_CURL_EXAMPLES.md.
# Semua endpoint di bawah path ini: /auth, /programs, /packages, /checkout, /student, /instructor.
# `npm run dev`: jika variabel ini tidak di-set, frontend otomatis memakai http://localhost:8080/api/v1 (bukan production).
VITE_API_URL=http://localhost:8080/api/v1

# (Opsional) Wilayah: pakai GET /geo/provinces & /geo/regencies/:id di backend (cache Redis).
# Kosong atau "public" = fetch langsung ke API publik emsifa + cache localStorage di browser.
# VITE_GEO_SOURCE=internal

# (Opsional) Base URL backend jika berbeda dari VITE_API_URL (mis. tryouts di server lain)
# VITE_API_BASE_URL=http://localhost:8080

# ID tryout untuk halaman leaderboard
VITE_TRYOUT_ID=6b5517c4-7708-409c-9dd7-eaa74878a007

# (Opsional) URL API artikel landing
# VITE_ARTICLES_API_URL=

# Thumbnail hero YouTube (disarankan di production — tanpa ini, hero pakai placeholder).
# Ambil 11 karakter dari https://www.youtube.com/watch?v=XXXXXXXXXXX
# VITE_HERO_YOUTUBE_VIDEO_ID=
