# Base URL API (LMS + landing packages + tryouts).
# Contoh: http://localhost:8080/api
# Frontend memakai ini untuk: auth, programs, checkout, student, instructor.
# URL packages = {base tanpa /api}/api/v1/packages, tryouts = {base tanpa /api}/api/v1/tryouts/...
VITE_API_URL=http://localhost:8080/api

# (Opsional) Base URL backend jika berbeda dari VITE_API_URL (mis. tryouts di server lain)
# VITE_API_BASE_URL=http://localhost:8080

# ID tryout untuk halaman leaderboard
VITE_TRYOUT_ID=6b5517c4-7708-409c-9dd7-eaa74878a007

# (Opsional) URL API artikel landing
# VITE_ARTICLES_API_URL=

# (Opsional) ID video YouTube untuk thumbnail hero
# VITE_HERO_YOUTUBE_VIDEO_ID=
